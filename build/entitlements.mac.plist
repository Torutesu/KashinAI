<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron requires these two under the Hardened Runtime (JIT + V8 code memory). -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Some Electron/Node native paths dlopen libraries at runtime. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- KashinAI shells out to helper scripts (osascript, swift, gbrain) via child_process. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.inherit</key>
  <true/>
  <!-- Screen capture / OCR and Apple Events (read context, paste back). -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
